								"pipeline": {
									"referenceName": "PIP_API_INDUSTRY_AT_PRICE_SALE_SUB_NEW",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"SaleDate": {
										"value": "@item().date",
										"type": "Expression"
									},
									"WhsalCd": {
										"value": "@item().codeid",
										"type": "Expression"
									}
								}
							}
						}
					]
				}
			}
		],
