				"typeProperties": {
					"source": {
						"type": "AzurePostgreSqlSource",
						"query": "truncate table cd_ods.tb_sf_eat_order_detail_date;\r\n\r\ninsert into cd_ods.tb_sf_eat_order_detail_date\r\nwith use_dt as\r\n(\r\nSELECT\r\n    cast(order_detail_id as varchar) as order_detail_id,\r\n    STRING_AGG(use_date, ',' ORDER BY use_date) AS use_date\r\nFROM (\r\n    SELECT DISTINCT\r\n        order_detail_id,\r\n        substr( use_date, 6, length(use_date)) as use_date\r\n    FROM cd_ods.tb_eat_order_detail_date\r\n    where order_detail_id in \r\n    (\r\n    \t\tselect order_detail_id from cd_ods.tb_sf_eat_order_detail\r\n    )\r\n) t\r\nGROUP BY\r\n    order_detail_id\r\n)\r\nselect * from use_dt;\r\n\r\nselect 1 as success",
						"partitionOption": "None",
						"queryTimeout": "02:00:00"
					},
