							"value": "INSERT INTO cd_ods.tb_d2b_competition_bid_result_company_list(\ndemandyear\n,dcsno\n,orntcode\n,iemno\n,opengdate\n,gpsTime\n,bidnQnty\n,bidnRank\n,bidnRate\n,bidnRslt\n,bidxDegr\n,bidxNote\n,bznsRgnb\n,mfkrName\n,middScor\n,mnufCode\n,pqcmDivs\n,prceScor\n,rptrKore\n,tbidAmnt\n,tbidLepr\n,tbidQnty\n,tbidUtpr\n,totaScor\n)\nselect\nt.demandyear ,\nt.dcsno ,\nt.orntcode ,\nt.iemno ,\nt.opengdate,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items' ->  'item' ->> 'gpsTime'                         as gpsTime,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'bidnQnty','\"',''), ''),\n    '0'\n)::numeric AS bidnQnty,\n    t.jsondata::jsonb -> 'response' -> 'body'  ->'items' ->  'item' ->> 'bidnRank'                        as bidnRank,\n          COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'bidnRate','\"',''), ''),\n    '0'\n)::numeric AS bidnRate,\n    t.jsondata::jsonb -> 'response' -> 'body'  ->'items' ->  'item' ->> 'bidnRslt'                      as bidnRslt,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'bidxDegr'                            as bidxDegr,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'bidxNote'                          as bidxNote,\n    t.jsondata::jsonb -> 'response' -> 'body'->'items'  ->  'item' ->> 'bznsRgnb'                            as bznsRgnb,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'mfkrName'                             as mfkrName,\n          COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'middScor','\"',''), ''),\n    '0'\n)::numeric AS middScor,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'mnufCode'                        as mnufCode,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'pqcmDivs'                           as pqcmDivs,\n  COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'prceScor','\"',''), ''),\n    '0'\n)::numeric AS prceScor,\n    t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'rptrKore'        as rptrKore,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'tbidAmnt','\"',''), ''),\n    '0'\n)::numeric AS tbidAmnt,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'tbidLepr','\"',''), ''),\n    '0'\n)::numeric AS tbidLepr,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'tbidQnty','\"',''), ''),\n    '0'\n)::numeric AS tbidQnty,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'tbidUtpr','\"',''), ''),\n    '0'\n)::numeric AS tbidUtpr,\n      COALESCE(\n    NULLIF(replace(t.jsondata::jsonb -> 'response' -> 'body' ->'items'  ->  'item' ->> 'totaScor','\"',''), ''),\n    '0'\n)::numeric AS totaScor\nFROM cd_ods.tb_d2b_competition_bid_result_company_list_raw_1 t;\n \nselect 1 as success",
