{
	"name": "PIP_API_INDUSTRY_FSK_I1420",
	"properties": {
		"description": "수요기관정보조회",
		"activities": [
			{
				"name": "Until1",
				"type": "Until",
				"dependsOn": [
					{
						"activity": "set cnt",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@and(less(variables('copyCount'), 1000), equals(variables('cnt'), 0))\n",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Set variable1",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "Copy data1_copy1_copy1",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "copyCount",
								"value": {
									"value": "@activity('Copy data1_copy1_copy1').output.rowsCopied",
									"type": "Expression"
								}
							}
						},
						{
							"name": "Lookup1",
							"type": "Lookup",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzurePostgreSqlSource",
									"query": {
										"value": "with year_data as (\n    select \n        count(*) as year_cnt,\n        coalesce(max(cast(st as numeric)), 0) as max_st,\n        coalesce(max(cast(ed as numeric)), 0) as max_ed\n    from cd_ods.tb_fsk_i1420\n    where evl_yr = '@{variables('yyyy')}'\n),\ntoday_data as (\n    select count(*) as today_cnt\n    from cd_ods.tb_fsk_i1420\n    where evl_yr = to_char(now(), 'yyyy')\n      and if_date >= date_trunc('day', now())\n      and if_date < date_trunc('day', now()) + interval '1 day'\n)\nselect\n    case\n        when y.year_cnt = 0 then 1  \n        when t.today_cnt = 0 then 0      \n        when y.max_st = 0 then 1\n        else y.max_st + 1000\n    end as st,\n    case\n        when y.year_cnt = 0 then 1000     \n        when t.today_cnt = 0 then 0     \n        when y.max_ed = 0 then 1000\n        else y.max_ed + 1000\n    end as ed\nfrom year_data y\ncross join today_data t",
										"type": "Expression"
									},
									"partitionOption": "None",
									"queryTimeout": "02:00:00"
								},
								"dataset": {
									"referenceName": "DTS_POSTGRESQL_SNK",
									"type": "DatasetReference",
									"parameters": {
										"SinkSchema": "1",
										"SinkTable": "1"
									}
								}
							}
						},
						{
							"name": "Copy data1_copy1_copy1",
							"type": "Copy",
							"dependsOn": [
								{
									"activity": "Lookup1",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 3,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "JsonSource",
									"additionalColumns": [
										{
											"name": "st",
											"value": {
												"value": "@activity('Lookup1').output.firstRow.st",
												"type": "Expression"
											}
										},
										{
											"name": "ed",
											"value": {
												"value": "@activity('Lookup1').output.firstRow.ed",
												"type": "Expression"
											}
